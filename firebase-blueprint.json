{
  "entities": {
    "User": {
      "title": "User",
      "description": "A member of the Colla",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "instrument": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Song": {
      "title": "Song",
      "description": "A piece of music in the repertoire",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "composer": { "type": "string" },
        "style": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "mp3Url": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "addedBy", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "A rehearsal or performance",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Assaig", "Actuació"] },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "date", "createdBy", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "A user's attendance status for an event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["Vull anar-hi", "No puc", "Pendent"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "userId", "status", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/songs/{songId}": {
      "schema": { "$ref": "#/entities/Song" },
      "description": "Repertoire collection"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Events collection"
    },
    "/attendances/{attendanceId}": {
      "schema": { "$ref": "#/entities/Attendance" },
      "description": "Attendances collection"
    }
  }
}
