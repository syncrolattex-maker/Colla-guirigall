rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "syncrolattex@gmail.com" && request.auth.token.email_verified == true));
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'instrument', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['admin', 'member'] &&
             (!('instrument' in data) || (data.instrument is string && data.instrument.size() < 50)) &&
             data.createdAt is string;
    }

    function isValidSong(data) {
      return hasOnlyAllowedFields(['title', 'composer', 'style', 'pdfUrl', 'mp3Url', 'youtubeUrl', 'addedBy', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             (!('composer' in data) || (data.composer is string && data.composer.size() < 100)) &&
             (!('style' in data) || (data.style is string && data.style.size() < 100)) &&
             (!('pdfUrl' in data) || (data.pdfUrl is string && data.pdfUrl.size() < 500)) &&
             (!('mp3Url' in data) || (data.mp3Url is string && data.mp3Url.size() < 500)) &&
             (!('youtubeUrl' in data) || (data.youtubeUrl is string && data.youtubeUrl.size() < 500)) &&
             data.addedBy is string && data.addedBy.size() > 0 && data.addedBy.size() < 100 &&
             data.createdAt is string;
    }

    function isValidEvent(data) {
      return hasOnlyAllowedFields(['title', 'type', 'date', 'location', 'notes', 'createdBy', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.type in ['Assaig', 'Actuació'] &&
             data.date is string && data.date.size() > 0 && data.date.size() < 50 &&
             (!('location' in data) || (data.location is string && data.location.size() < 200)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000)) &&
             data.createdBy is string && data.createdBy.size() > 0 && data.createdBy.size() < 100 &&
             data.createdAt is string;
    }

    function isValidAttendance(data) {
      return hasOnlyAllowedFields(['eventId', 'userId', 'status', 'updatedAt']) &&
             data.eventId is string && data.eventId.size() > 0 && data.eventId.size() < 100 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.status in ['Vull anar-hi', 'No puc', 'Pendent'] &&
             data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) &&
                    uidUnchanged() &&
                    ((isOwner(userId) && request.resource.data.role == 'member') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) &&
                    uidNotModified() &&
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /songs/{songId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidSong(request.resource.data);
      allow update: if isAdmin() && isValidSong(request.resource.data);
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidEvent(request.resource.data);
      allow update: if isAdmin() && isValidEvent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendances/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAttendance(request.resource.data) &&
                    (isOwner(request.resource.data.userId) || isAdmin());
      allow update: if isAuthenticated() && isValidAttendance(request.resource.data) &&
                    (isOwner(request.resource.data.userId) || isAdmin()) &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.eventId == resource.data.eventId;
      allow delete: if isAdmin();
    }
  }
}
